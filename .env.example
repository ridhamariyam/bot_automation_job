# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jobrocket:password@localhost:5432/jobrocket

# ── Redis (ARQ job queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Or split form (used when REDIS_URL is not set):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production

# Fernet key for encrypting stored platform passwords.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── SMTP (Gmail) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# ── Paddle Billing ─────────────────────────────────────────────────────────
PADDLE_SANDBOX=true
PADDLE_API_KEY=your_paddle_api_key
PADDLE_CLIENT_TOKEN=your_paddle_client_token
PADDLE_WEBHOOK_SECRET=your_webhook_secret
PADDLE_PRICE_PRO=your_pro_price_id
PADDLE_PRICE_PREMIUM=your_premium_price_id

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: comma-separated extra origins for CORS (e.g. Vercel preview URLs)
# EXTRA_CORS_ORIGINS=https://my-preview--bot-automation-job.vercel.app

# ── OpenAI (cover letters, resume tailoring, hiring post detection) ────────
OPENAI_API_KEY=sk-...

# ── Twilio WhatsApp ────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com — use sandbox for testing
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Sandbox default: whatsapp:+14155238886
# Production: whatsapp:+your_verified_number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Bot runner (subprocess / CLI mode only) ────────────────────────────────
BOT_API_URL=http://localhost:8000
BOT_USER_EMAIL=test@example.com
# BOT_TOKEN=eyJ...  (JWT obtained from /api/auth/login)
BOT_MAX_JOBS=50

# ── Display (Linux headless Playwright) ───────────────────────────────────
DISPLAY=:0
